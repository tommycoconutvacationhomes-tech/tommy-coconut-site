# Tommy Coconut Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# ============================================
# CLOUDINARY (Image Optimization) - CONFIGURED
# ============================================
CLOUDINARY_CLOUD_NAME=dhschyq40
CLOUDINARY_API_KEY=442886661115165
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ============================================
# SUPABASE (Database) - REQUIRED
# ============================================
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_service_key

# ============================================
# AIRTABLE (Business Workflows) - REQUIRED
# ============================================
# Get PAT from: https://airtable.com/create/tokens
# Get Base ID from your Airtable base URL
AIRTABLE_PAT=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_GUESTS_TABLE_ID=tblGuestInquiries
AIRTABLE_BOOKINGS_TABLE_ID=tblBookings
AIRTABLE_PROPERTIES_TABLE_ID=tblProperties

# ============================================
# EMAIL (SendGrid) - RECOMMENDED
# ============================================
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=hello@tommycoconut.com
NOTIFICATION_EMAIL=bookings@tommycoconut.com

# ============================================
# MONITORING (Sentry) - RECOMMENDED
# ============================================
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
SENTRY_DSN=https://XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX@oXXXXXXX.ingest.sentry.io/XXXXXXX
LOG_LEVEL=info
NODE_ENV=production

# ============================================
# WHATSAPP BUSINESS API - OPTIONAL
# ============================================
# Get from: https://developers.facebook.com/apps/YOUR_APP/whatsapp-business/wa-dev-console/
WHATSAPP_PHONE_NUMBER_ID=XXXXXXXXXXXXXXXXX
WHATSAPP_ACCESS_TOKEN=EAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# ============================================
# SECURITY - OPTIONAL
# ============================================
# Generate with: openssl rand -hex 32
API_KEY=your_api_key_for_protected_endpoints_here
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=10
ALLOWED_ORIGINS=https://tommycoconut.com,https://www.tommycoconut.com,https://tommy-coconut-site.netlify.app

# ============================================
# STRIPE (Payments) - FUTURE
# ============================================
# STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
# STRIPE_SECRET_KEY=sk_live_your_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here